# DevForge - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ==================== 服务器配置 ====================

# API Server 端口
PORT=3000

# API Server 绑定地址 (0.0.0.0 允许外部访问)
HOST=0.0.0.0

# ==================== 认证配置 ====================

# 管理员用户名
ADMIN_USER=admin

# 管理员密码
ADMIN_PASSWORD=admin

# ==================== Agent 配置 ====================

# Agent 执行器连接的 API 地址
API_BASE=http://localhost:3000

# 覆盖默认模型配置（可选）
# AGENT_MODEL=opencode/qwen3.6-plus

# 新建 Sprint 时默认「代码开发引擎」：opencode | cursor_auto（Dashboard 可改）
# DEVFORGE_DEVELOPER_BACKEND=opencode

# Cursor CLI（仅当 developer 选择 Cursor CLI 时）https://cursor.com/cli
# CURSOR_CLI=cursor
# 传给 cursor 的子命令与参数（空格分隔；默认 agent chat --print --force，按本机 Cursor 版本调整）
# CURSOR_CLI_ARGS=agent chat --print --force
# CURSOR_API_KEY=
